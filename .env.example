# Copy this file to .env and fill in COPILOT_GITHUB_TOKEN.
# On Windows, run: pwsh scripts\extract-token.ps1
# That script reads the OAuth token from the `copilot` CLI's Credential Manager
# entry and writes COPILOT_GITHUB_TOKEN= here automatically.

# REQUIRED. The GitHub OAuth token (gho_...) used by your `copilot` CLI.
COPILOT_GITHUB_TOKEN=

# Optional overrides — defaults are correct for the standard tenant.
# COPILOT_PROXY_PORT=4141
# COPILOT_API_BASE=https://api.githubcopilot.com
# COPILOT_INTEGRATION_ID=copilot-developer-cli
# COPILOT_EDITOR_VERSION=claude-copilot-cli-relay/0.1.0
# LOG_LEVEL=info
# LOG_BODIES=0
